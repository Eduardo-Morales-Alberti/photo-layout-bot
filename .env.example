# Required: token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Optional layout tuning (defaults shown)
DPI=300
MAX_LONG_CM=16
MAX_SHORT_CM=13
# Images may shrink down to this min box to fit more per page (set equal to
# the MAX values to disable shrinking and always use the max size).
MIN_LONG_CM=12
MIN_SHORT_CM=9
MARGIN_CM=0
GAP_CM=0
ALLOW_UPSCALE=true
ALLOW_ROTATE=true
# Grow a page's images to fill leftover space (never beyond the max box)
FILL_PAGE=true

# Output: PNG (lossless, recommended) or JPEG
OUT_FORMAT=PNG
JPEG_QUALITY=95

# Seconds to wait after the last photo before auto-composing
DEBOUNCE_SECONDS=2.5
